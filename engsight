#!/usr/bin/env bash
# engsight — personal engineering insight tool
set -euo pipefail

ENGSIGHT_DIR="${HOME}/.engsight"
HOOKS_SOURCE="${ENGSIGHT_DIR}/templates/hooks"

DB="${ENGSIGHT_DIR}/engsight.db"

usage() {
  echo "Usage: engsight <command>"
  echo ""
  echo "Commands:"
  echo "  init             Install engsight hooks in the current repo"
  echo "  init-all PATH    Install engsight hooks in all repos under a path"
  echo "  status           Show engsight status for current repo"
  echo "  log              Show recent events across all repos"
  echo "  repos            List repos with activity counts"
  echo "  summary          Summarize activity for a time period"
  echo "  sessions         Reconstruct work sessions from event clusters"
  echo "  patterns         Surface working patterns and insights"
  echo "  diff             Compare activity between two time periods"
  echo ""
  echo "Options for log:"
  echo "  --repo NAME      Filter by repo name"
  echo "  --type TYPE      Filter by event type (commit, checkout, push, etc.)"
  echo "  --since DATE     Show events after DATE (YYYY-MM-DD)"
  echo "  --limit N        Max events to show (default: 20)"
  echo ""
  echo "Options for repos:"
  echo "  --since DATE     Show repos with activity after DATE"
  echo ""
  echo "Options for summary:"
  echo "  --daily          Summarize today"
  echo "  --weekly         Summarize last 7 days (default)"
  echo "  --since DATE     Custom start date (YYYY-MM-DD)"
  echo "  --until DATE     Custom end date (YYYY-MM-DD, default: today)"
  echo ""
  echo "Options for sessions:"
  echo "  --since DATE     Show sessions after DATE"
  echo "  --until DATE     Show sessions before DATE"
  echo "  --gap MINUTES    Gap threshold for session boundary (default: 30)"
  echo "  --repo NAME      Filter by repo name"
  echo "  --limit N        Max sessions to show (default: 20)"
  echo ""
  echo "Options for patterns:"
  echo "  --daily          Analyze today"
  echo "  --weekly         Analyze last 7 days (default)"
  echo "  --since DATE     Custom start date (YYYY-MM-DD)"
  echo "  --until DATE     Custom end date (YYYY-MM-DD, default: today)"
  echo ""
  echo "Options for diff:"
  echo "  --weekly         Compare this week vs last week (default)"
  echo "  --monthly        Compare this month vs last month"
  echo "  --period A B     Compare two custom periods: A=YYYY-MM-DD..YYYY-MM-DD"
  echo ""
}

cmd_init() {
  local git_dir
  git_dir="$(git rev-parse --git-dir 2>/dev/null)" || {
    echo "Error: not a git repository" >&2
    exit 1
  }

  local hooks_dir="${git_dir}/hooks"
  mkdir -p "$hooks_dir"

  echo "Installing engsight hooks in $(git rev-parse --show-toplevel)..."

  for hook_src in "${HOOKS_SOURCE}"/*; do
    local hook_name
    hook_name="$(basename "$hook_src")"
    local hook_dest="${hooks_dir}/${hook_name}"

    # If a local hook already exists and isn't an engsight hook, rename it
    if [[ -f "$hook_dest" ]]; then
      if ! grep -q "engsight" "$hook_dest" 2>/dev/null; then
        mv "$hook_dest" "${hook_dest}.local"
        echo "  Renamed existing ${hook_name} -> ${hook_name}.local"
      else
        echo "  ${hook_name} already installed (skipped)"
        continue
      fi
    fi

    cp "$hook_src" "$hook_dest"
    chmod +x "$hook_dest"
    echo "  Installed ${hook_name}"
  done

  echo "Done!"
}

cmd_init_all() {
  local search_path="${1:-$(pwd)}"

  if [[ ! -d "$search_path" ]]; then
    echo "Error: '$search_path' is not a directory" >&2
    exit 1
  fi

  echo "Finding git repos under ${search_path}..."
  local count=0
  local failed=0

  while IFS= read -r git_dir; do
    local repo_dir
    repo_dir="$(dirname "$git_dir")"
    echo ""
    echo "--- $(basename "$repo_dir") ---"
    if (cd "$repo_dir" && cmd_init); then
      count=$(( count + 1 ))
    else
      echo "  FAILED"
      failed=$(( failed + 1 ))
    fi
  done < <(find "$search_path" -name .git -type d -not -path '*/node_modules/*' -not -path '*/.git/modules/*' 2>/dev/null)

  echo ""
  echo "Initialized ${count} repos. ${failed} failed."
}

cmd_status() {
  local repo_path
  repo_path="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Error: not a git repository" >&2
    exit 1
  }

  local repo_name
  repo_name="$(basename "$repo_path")"

  echo "engsight status for ${repo_name}"
  echo "  Repo: ${repo_path}"

  # Check installed hooks
  local git_dir
  git_dir="$(git rev-parse --git-dir 2>/dev/null)"
  local hooks_dir="${git_dir}/hooks"
  local installed=0

  for hook_name in post-commit pre-commit post-checkout post-merge pre-push pre-rebase post-rewrite; do
    if [[ -f "${hooks_dir}/${hook_name}" ]] && grep -q "engsight" "${hooks_dir}/${hook_name}" 2>/dev/null; then
      installed=$(( installed + 1 ))
    fi
  done
  echo "  Hooks installed: ${installed}/7"

  # Event count
  if [[ -f "${ENGSIGHT_DIR}/engsight.db" ]]; then
    source "${ENGSIGHT_DIR}/common.sh" 2>/dev/null
    engsight_load_config
    local total
    total="$(sqlite3 "$ENGSIGHT_DB" "SELECT COUNT(*) FROM events WHERE repo_path='${repo_path}';" 2>/dev/null || echo 0)"
    local latest
    latest="$(sqlite3 "$ENGSIGHT_DB" "SELECT timestamp FROM events WHERE repo_path='${repo_path}' ORDER BY timestamp DESC LIMIT 1;" 2>/dev/null || echo "none")"
    echo "  Events recorded: ${total}"
    echo "  Latest event: ${latest}"
  else
    echo "  Database: not found"
  fi
}

# --- Date helpers (BSD/GNU compat, matches engleader.tools) ---

if date -v +0d >/dev/null 2>&1; then
  # BSD date (macOS)
  _engsight_date_ago() { date -v-"$1"d +"%Y-%m-%d"; }
  _engsight_to_epoch() { date -j -f "%Y-%m-%dT%H:%M:%SZ" "$1" "+%s" 2>/dev/null || echo 0; }
else
  # GNU date
  _engsight_date_ago() { date -d "$1 days ago" +"%Y-%m-%d"; }
  _engsight_to_epoch() { date -d "$1" "+%s" 2>/dev/null || echo 0; }
fi

_engsight_format_duration() {
  local seconds="$1"
  if [[ "$seconds" -lt 60 ]]; then
    printf '%ds' "$seconds"
  elif [[ "$seconds" -lt 3600 ]]; then
    printf '%dm' $(( seconds / 60 ))
  else
    local h=$(( seconds / 3600 ))
    local m=$(( (seconds % 3600) / 60 ))
    if [[ "$m" -gt 0 ]]; then
      printf '%dh %dm' "$h" "$m"
    else
      printf '%dh' "$h"
    fi
  fi
}

# --- Query helpers ---

_engsight_check_db() {
  if [[ ! -f "$DB" ]]; then
    echo "Error: database not found at ${DB}" >&2
    echo "Run install.sh first." >&2
    exit 1
  fi
}

_engsight_event_detail() {
  # Extract a one-line detail from a payload based on event type
  local event_type="$1" payload="$2"
  case "$event_type" in
    commit)
      local msg
      msg="$(echo "$payload" | sqlite3 :memory: "SELECT json_extract('${payload}', '$.message');" 2>/dev/null || echo "")"
      # First line only, truncate
      msg="${msg%%$'\n'*}"
      if [[ ${#msg} -gt 60 ]]; then msg="${msg:0:57}..."; fi
      printf '%s' "$msg"
      ;;
    checkout)
      local prev new
      prev="$(echo "$payload" | sqlite3 :memory: "SELECT json_extract('${payload}', '$.previous_branch');" 2>/dev/null || echo "?")"
      new="$(echo "$payload" | sqlite3 :memory: "SELECT json_extract('${payload}', '$.new_branch');" 2>/dev/null || echo "?")"
      printf '%s -> %s' "$prev" "$new"
      ;;
    push)
      local count
      count="$(echo "$payload" | sqlite3 :memory: "SELECT json_extract('${payload}', '$.commits_being_pushed');" 2>/dev/null || echo "?")"
      printf '%s commit(s) pushed' "$count"
      ;;
    merge)
      local merged
      merged="$(echo "$payload" | sqlite3 :memory: "SELECT json_extract('${payload}', '$.merged_branch');" 2>/dev/null || echo "?")"
      printf 'merged %s' "$merged"
      ;;
    rewrite)
      local action
      action="$(echo "$payload" | sqlite3 :memory: "SELECT json_extract('${payload}', '$.action');" 2>/dev/null || echo "?")"
      printf '%s' "$action"
      ;;
    pre_commit)
      printf 'staged files checked'
      ;;
    rebase)
      local upstream
      upstream="$(echo "$payload" | sqlite3 :memory: "SELECT json_extract('${payload}', '$.upstream');" 2>/dev/null || echo "?")"
      printf 'onto %s' "$upstream"
      ;;
    *)
      printf '%s' ""
      ;;
  esac
}

# --- log command ---

cmd_log() {
  _engsight_check_db

  local repo="" event_type="" since="" limit=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)     repo="$2"; shift 2 ;;
      --type)     event_type="$2"; shift 2 ;;
      --since)    since="$2"; shift 2 ;;
      --limit)    limit="$2"; shift 2 ;;
      -h|--help)  usage; exit 0 ;;
      *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local where="1=1"
  [[ -n "$repo" ]] && where="${where} AND repo_name='${repo}'"
  [[ -n "$event_type" ]] && where="${where} AND event_type='${event_type}'"
  [[ -n "$since" ]] && where="${where} AND timestamp >= '${since}T00:00:00Z'"

  local query="SELECT timestamp, event_type, repo_name, branch, payload FROM events WHERE ${where} ORDER BY timestamp DESC LIMIT ${limit};"

  local count
  count="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where};")"

  if [[ "$count" -eq 0 ]]; then
    echo "No events found."
    return
  fi

  printf "%-20s %-12s %-20s %-15s %s\n" "Timestamp" "Type" "Repo" "Branch" "Detail"
  printf "%s\n" "────────────────────────────────────────────────────────────────────────────────────────────"

  while IFS='|' read -r ts etype rname branch payload; do
    local detail
    detail="$(_engsight_event_detail "$etype" "$payload")"
    # Format timestamp: strip seconds and Z for readability
    local display_ts="${ts%:*}"
    display_ts="${display_ts/T/ }"
    printf "%-20s %-12s %-20s %-15s %s\n" "$display_ts" "$etype" "$rname" "$branch" "$detail"
  done < <(sqlite3 "$DB" "$query")

  if [[ "$count" -gt "$limit" ]]; then
    echo ""
    echo "Showing ${limit} of ${count} events. Use --limit to see more."
  fi
}

# --- repos command ---

cmd_repos() {
  _engsight_check_db

  local since=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)    since="$2"; shift 2 ;;
      -h|--help)  usage; exit 0 ;;
      *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local where="1=1"
  [[ -n "$since" ]] && where="timestamp >= '${since}T00:00:00Z'"

  local query="SELECT repo_name, COUNT(*) as event_count,
    SUM(CASE WHEN event_type='commit' THEN 1 ELSE 0 END) as commits,
    SUM(CASE WHEN event_type='checkout' THEN 1 ELSE 0 END) as checkouts,
    MAX(timestamp) as last_active
    FROM events WHERE ${where}
    GROUP BY repo_name ORDER BY event_count DESC;"

  local total_repos
  total_repos="$(sqlite3 "$DB" "SELECT COUNT(DISTINCT repo_name) FROM events WHERE ${where};")"

  if [[ "$total_repos" -eq 0 ]]; then
    echo "No repos with activity found."
    return
  fi

  echo "Active repos: ${total_repos}"
  echo ""
  printf "%-25s %8s %8s %10s   %-20s\n" "Repo" "Events" "Commits" "Switches" "Last Active"
  printf "%s\n" "────────────────────────────────────────────────────────────────────────────────────────"

  while IFS='|' read -r rname event_count commits checkouts last_active; do
    local display_ts="${last_active%:*}"
    display_ts="${display_ts/T/ }"
    printf "%-25s %8s %8s %10s   %-20s\n" "$rname" "$event_count" "$commits" "$checkouts" "$display_ts"
  done < <(sqlite3 "$DB" "$query")
}

# --- summary command ---

cmd_summary() {
  _engsight_check_db

  local since="" until_date="" mode="weekly"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --daily)    mode="daily"; shift ;;
      --weekly)   mode="weekly"; shift ;;
      --since)    since="$2"; mode="custom"; shift 2 ;;
      --until)    until_date="$2"; shift 2 ;;
      -h|--help)  usage; exit 0 ;;
      *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  # Resolve date range
  case "$mode" in
    daily)
      since="$(_engsight_date_ago 0)"
      until_date="$(_engsight_date_ago 0)"
      ;;
    weekly)
      since="$(_engsight_date_ago 7)"
      until_date="$(_engsight_date_ago 0)"
      ;;
    custom)
      [[ -z "$since" ]] && { echo "Error: --since required for custom range" >&2; exit 1; }
      [[ -z "$until_date" ]] && until_date="$(_engsight_date_ago 0)"
      ;;
  esac

  local ts_start="${since}T00:00:00Z"
  local ts_end="${until_date}T23:59:59Z"
  local where="timestamp >= '${ts_start}' AND timestamp <= '${ts_end}'"

  local total
  total="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where};")"

  if [[ "$total" -eq 0 ]]; then
    echo "No activity from ${since} to ${until_date}."
    return
  fi

  # Header
  if [[ "$mode" == "daily" ]]; then
    echo "Daily Summary: ${since}"
  elif [[ "$mode" == "weekly" ]]; then
    echo "Weekly Summary: ${since} to ${until_date}"
  else
    echo "Summary: ${since} to ${until_date}"
  fi
  printf "%s\n" "────────────────────────────────────────────"

  # Overview
  local repos commits checkouts pushes merges
  repos="$(sqlite3 "$DB" "SELECT COUNT(DISTINCT repo_name) FROM events WHERE ${where};")"
  commits="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit';")"
  checkouts="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='checkout';")"
  pushes="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='push';")"
  merges="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='merge';")"

  echo ""
  echo "Overview"
  printf "  • Repos active:       %d\n" "$repos"
  printf "  • Commits:            %d\n" "$commits"
  printf "  • Branch switches:    %d\n" "$checkouts"
  printf "  • Pushes:             %d\n" "$pushes"
  printf "  • Merges:             %d\n" "$merges"
  printf "  • Total events:       %d\n" "$total"

  # Per-repo breakdown
  echo ""
  echo "Repos"
  printf "%s\n" "────────────────────────────────────────────"

  while IFS='|' read -r rname rcommits revents; do
    printf "  %-25s %d commits (%d events)\n" "$rname" "$rcommits" "$revents"
  done < <(sqlite3 "$DB" "SELECT repo_name, SUM(CASE WHEN event_type='commit' THEN 1 ELSE 0 END), COUNT(*) FROM events WHERE ${where} GROUP BY repo_name ORDER BY 2 DESC;")

  # AI co-authorship breakdown
  echo ""
  echo "AI Co-authorship"
  printf "%s\n" "────────────────────────────────────────────"

  local ai_commits
  ai_commits="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND json_extract(payload, '$.ai_commit_signals.co_authored_by') != '[]';")"

  if [[ "$commits" -gt 0 ]]; then
    local ai_pct
    ai_pct="$(awk "BEGIN { printf \"%.0f\", (${ai_commits}/${commits})*100 }")"
    printf "  • AI co-authored:     %d / %d commits (%s%%)\n" "$ai_commits" "$commits" "$ai_pct"
  else
    printf "  • AI co-authored:     0 commits\n"
  fi

  # Break down by co-author name
  local coauthor_data
  coauthor_data="$(sqlite3 "$DB" "
    SELECT value FROM events, json_each(json_extract(payload, '$.ai_commit_signals.co_authored_by'))
    WHERE ${where} AND event_type='commit'
    AND json_extract(payload, '$.ai_commit_signals.co_authored_by') != '[]';" 2>/dev/null || echo "")"

  if [[ -n "$coauthor_data" ]]; then
    echo ""
    echo "  By tool:"
    echo "$coauthor_data" | sort | uniq -c | sort -rn | while read -r count name; do
      printf "    %-20s %d commits\n" "$name" "$count"
    done
  fi

  # Pattern matches
  local pattern_data
  pattern_data="$(sqlite3 "$DB" "
    SELECT value FROM events, json_each(json_extract(payload, '$.ai_commit_signals.pattern_matches'))
    WHERE ${where} AND event_type='commit'
    AND json_extract(payload, '$.ai_commit_signals.pattern_matches') != '[]';" 2>/dev/null || echo "")"

  if [[ -n "$pattern_data" ]]; then
    echo ""
    echo "  Patterns detected:"
    echo "$pattern_data" | sort | uniq -c | sort -rn | while read -r count pattern; do
      printf "    %-30s %d matches\n" "$pattern" "$count"
    done
  fi

  # AI artifacts presence
  local repos_with_artifacts
  repos_with_artifacts="$(sqlite3 "$DB" "
    SELECT DISTINCT repo_name FROM events
    WHERE ${where} AND event_type='pre_commit'
    AND json_extract(payload, '$.ai_artifacts') != '{}';" 2>/dev/null || echo "")"

  if [[ -n "$repos_with_artifacts" ]]; then
    echo ""
    echo "  Repos with AI artifacts:"
    echo "$repos_with_artifacts" | while read -r rname; do
      # Get the most recent artifact scan for this repo
      local artifacts
      artifacts="$(sqlite3 "$DB" "
        SELECT json_extract(payload, '$.ai_artifacts') FROM events
        WHERE ${where} AND event_type='pre_commit' AND repo_name='${rname}'
        AND json_extract(payload, '$.ai_artifacts') != '{}'
        ORDER BY timestamp DESC LIMIT 1;" 2>/dev/null || echo "{}")"
      # List artifact keys
      local keys
      keys="$(sqlite3 :memory: "SELECT key FROM json_each('${artifacts}');" 2>/dev/null | paste -sd', ' -)"
      printf "    %-25s %s\n" "$rname" "$keys"
    done
  fi

  # Time patterns
  if [[ "$commits" -gt 0 ]]; then
    echo ""
    echo "Time Patterns"
    printf "%s\n" "────────────────────────────────────────────"

    # Commits by hour bucket
    local morning afternoon evening night
    morning="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND CAST(json_extract(payload, '$.time_context.hour') AS INTEGER) BETWEEN 6 AND 11;")"
    afternoon="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND CAST(json_extract(payload, '$.time_context.hour') AS INTEGER) BETWEEN 12 AND 17;")"
    evening="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND CAST(json_extract(payload, '$.time_context.hour') AS INTEGER) BETWEEN 18 AND 22;")"
    night="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND (CAST(json_extract(payload, '$.time_context.hour') AS INTEGER) >= 23 OR CAST(json_extract(payload, '$.time_context.hour') AS INTEGER) < 6);")"

    printf "  • Morning (6–11):     %d commits\n" "$morning"
    printf "  • Afternoon (12–17):  %d commits\n" "$afternoon"
    printf "  • Evening (18–22):    %d commits\n" "$evening"
    printf "  • Night (23–5):       %d commits\n" "$night"

    # Weekend vs weekday
    local weekend_commits
    weekend_commits="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND json_extract(payload, '$.time_context.is_weekend') = 'true';" 2>/dev/null || echo 0)"
    local weekday_commits=$(( commits - weekend_commits ))
    printf "  • Weekday:            %d commits\n" "$weekday_commits"
    printf "  • Weekend:            %d commits\n" "$weekend_commits"
  fi
}

# --- sessions command ---

cmd_sessions() {
  _engsight_check_db

  local since="" until_date="" gap=30 repo="" limit=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)    since="$2"; shift 2 ;;
      --until)    until_date="$2"; shift 2 ;;
      --gap)      gap="$2"; shift 2 ;;
      --repo)     repo="$2"; shift 2 ;;
      --limit)    limit="$2"; shift 2 ;;
      -h|--help)  usage; exit 0 ;;
      *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  [[ -z "$since" ]] && since="$(_engsight_date_ago 7)"
  [[ -z "$until_date" ]] && until_date="$(_engsight_date_ago 0)"

  local ts_start="${since}T00:00:00Z"
  local ts_end="${until_date}T23:59:59Z"
  local where="timestamp >= '${ts_start}' AND timestamp <= '${ts_end}'"
  [[ -n "$repo" ]] && where="${where} AND repo_name='${repo}'"

  local gap_seconds=$(( gap * 60 ))

  # Pull all events sorted by time
  local events_data
  events_data="$(sqlite3 "$DB" "SELECT timestamp, event_type, repo_name, branch, json_extract(payload, '$.ai_commit_signals.co_authored_by') FROM events WHERE ${where} ORDER BY timestamp ASC;")"

  if [[ -z "$events_data" ]]; then
    echo "No events from ${since} to ${until_date}."
    return
  fi

  # Walk events and group into sessions
  local sessions=()
  local s_start="" s_end="" s_repos="" s_branches="" s_commits=0 s_events=0
  local s_checkouts=0 s_ai_commits=0 s_prev_epoch=0

  _flush_session() {
    if [[ -z "$s_start" ]]; then return; fi
    local s_start_epoch s_end_epoch duration
    s_start_epoch="$(_engsight_to_epoch "$s_start")"
    s_end_epoch="$(_engsight_to_epoch "$s_end")"
    duration=$(( s_end_epoch - s_start_epoch ))
    # Deduplicate repos and branches
    local repo_list branch_list repo_count
    repo_list="$(echo "$s_repos" | tr ',' '\n' | sort -u | paste -sd',' -)"
    branch_list="$(echo "$s_branches" | tr ',' '\n' | sort -u | paste -sd',' -)"
    repo_count="$(echo "$repo_list" | tr ',' '\n' | wc -l | tr -d ' ')"
    sessions+=("${s_start}|${s_end}|${duration}|${repo_list}|${repo_count}|${s_commits}|${s_checkouts}|${s_ai_commits}|${s_events}|${branch_list}")
  }

  while IFS='|' read -r ts etype rname branch ai_coauthors; do
    local epoch
    epoch="$(_engsight_to_epoch "$ts")"

    # Check if this starts a new session
    if [[ -z "$s_start" ]] || [[ $(( epoch - s_prev_epoch )) -gt $gap_seconds ]]; then
      _flush_session
      s_start="$ts"
      s_end="$ts"
      s_repos="$rname"
      s_branches="$branch"
      s_commits=0
      s_events=0
      s_checkouts=0
      s_ai_commits=0
    else
      s_end="$ts"
      s_repos="${s_repos},${rname}"
      s_branches="${s_branches},${branch}"
    fi

    s_events=$(( s_events + 1 ))
    s_prev_epoch="$epoch"

    if [[ "$etype" == "commit" ]]; then
      s_commits=$(( s_commits + 1 ))
      if [[ -n "$ai_coauthors" && "$ai_coauthors" != "[]" ]]; then
        s_ai_commits=$(( s_ai_commits + 1 ))
      fi
    fi
    if [[ "$etype" == "checkout" ]]; then
      s_checkouts=$(( s_checkouts + 1 ))
    fi
  done <<< "$events_data"
  _flush_session

  local total_sessions=${#sessions[@]}
  if [[ "$total_sessions" -eq 0 ]]; then
    echo "No sessions reconstructed."
    return
  fi

  echo "Sessions: ${total_sessions} (gap threshold: ${gap}m)"
  echo "Period: ${since} to ${until_date}"
  echo ""
  printf "%-17s %8s %6s %8s %4s %s\n" "Start" "Duration" "Cmts" "Switches" "AI" "Repos"
  printf "%s\n" "────────────────────────────────────────────────────────────────────────────────────"

  # Show sessions in reverse chronological order, limited
  local shown=0
  for (( i=${#sessions[@]}-1; i>=0; i-- )); do
    if [[ "$shown" -ge "$limit" ]]; then break; fi
    IFS='|' read -r ss_start ss_end ss_dur ss_repos ss_rcount ss_commits ss_checkouts ss_ai ss_events ss_branches <<< "${sessions[$i]}"

    local display_start="${ss_start%:*}"
    display_start="${display_start/T/ }"
    local dur_display
    dur_display="$(_engsight_format_duration "$ss_dur")"

    local ai_indicator=""
    if [[ "$ss_ai" -gt 0 ]]; then
      ai_indicator="${ss_ai}"
    else
      ai_indicator="-"
    fi

    # Truncate repo list if too long
    local repo_display="$ss_repos"
    if [[ ${#repo_display} -gt 35 ]]; then
      repo_display="${repo_display:0:32}..."
    fi

    printf "%-17s %8s %6d %8d %4s %s\n" "$display_start" "$dur_display" "$ss_commits" "$ss_checkouts" "$ai_indicator" "$repo_display"
    shown=$(( shown + 1 ))
  done

  if [[ "$total_sessions" -gt "$limit" ]]; then
    echo ""
    echo "Showing ${limit} of ${total_sessions} sessions. Use --limit to see more."
  fi
}

# --- patterns command ---

cmd_patterns() {
  _engsight_check_db

  local since="" until_date="" mode="weekly" gap=30

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --daily)    mode="daily"; shift ;;
      --weekly)   mode="weekly"; shift ;;
      --since)    since="$2"; mode="custom"; shift 2 ;;
      --until)    until_date="$2"; shift 2 ;;
      --gap)      gap="$2"; shift 2 ;;
      -h|--help)  usage; exit 0 ;;
      *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  case "$mode" in
    daily)   since="$(_engsight_date_ago 0)"; until_date="$(_engsight_date_ago 0)" ;;
    weekly)  since="$(_engsight_date_ago 7)"; until_date="$(_engsight_date_ago 0)" ;;
    custom)
      [[ -z "$since" ]] && { echo "Error: --since required" >&2; exit 1; }
      [[ -z "$until_date" ]] && until_date="$(_engsight_date_ago 0)"
      ;;
  esac

  local ts_start="${since}T00:00:00Z"
  local ts_end="${until_date}T23:59:59Z"
  local where="timestamp >= '${ts_start}' AND timestamp <= '${ts_end}'"
  local gap_seconds=$(( gap * 60 ))

  local total_events
  total_events="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where};")"

  if [[ "$total_events" -eq 0 ]]; then
    echo "No activity from ${since} to ${until_date}."
    return
  fi

  local commits
  commits="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit';")"

  echo "Patterns: ${since} to ${until_date}"
  printf "%s\n" "════════════════════════════════════════════════════════════"

  # --- Reconstruct sessions for analysis ---
  local events_data
  events_data="$(sqlite3 "$DB" "SELECT timestamp, event_type, repo_name, branch, json_extract(payload, '$.ai_commit_signals.co_authored_by'), json_extract(payload, '$.files_changed') FROM events WHERE ${where} ORDER BY timestamp ASC;")"

  # Session reconstruction (same logic as cmd_sessions)
  local -a sess_durations=() sess_commits=() sess_ai_commits=() sess_repo_counts=()
  local -a sess_checkouts=() sess_files=() sess_repos_list=()
  local s_start="" s_end="" s_repos="" s_commits=0 s_events=0
  local s_checkouts=0 s_ai_commits=0 s_prev_epoch=0 s_files=0

  _flush_pattern_session() {
    if [[ -z "$s_start" ]]; then return; fi
    local s_start_epoch s_end_epoch duration repo_count
    s_start_epoch="$(_engsight_to_epoch "$s_start")"
    s_end_epoch="$(_engsight_to_epoch "$s_end")"
    duration=$(( s_end_epoch - s_start_epoch ))
    repo_count="$(echo "$s_repos" | tr ',' '\n' | sort -u | wc -l | tr -d ' ')"
    local repo_list
    repo_list="$(echo "$s_repos" | tr ',' '\n' | sort -u | paste -sd',' -)"
    sess_durations+=("$duration")
    sess_commits+=("$s_commits")
    sess_ai_commits+=("$s_ai_commits")
    sess_repo_counts+=("$repo_count")
    sess_checkouts+=("$s_checkouts")
    sess_files+=("$s_files")
    sess_repos_list+=("$repo_list")
  }

  while IFS='|' read -r ts etype rname branch ai_coauthors files_changed; do
    local epoch
    epoch="$(_engsight_to_epoch "$ts")"

    if [[ -z "$s_start" ]] || [[ $(( epoch - s_prev_epoch )) -gt $gap_seconds ]]; then
      _flush_pattern_session
      s_start="$ts"
      s_end="$ts"
      s_repos="$rname"
      s_commits=0
      s_events=0
      s_checkouts=0
      s_ai_commits=0
      s_files=0
    else
      s_end="$ts"
      s_repos="${s_repos},${rname}"
    fi

    s_events=$(( s_events + 1 ))
    s_prev_epoch="$epoch"

    if [[ "$etype" == "commit" ]]; then
      s_commits=$(( s_commits + 1 ))
      s_files=$(( s_files + ${files_changed:-0} ))
      if [[ -n "$ai_coauthors" && "$ai_coauthors" != "[]" ]]; then
        s_ai_commits=$(( s_ai_commits + 1 ))
      fi
    fi
    if [[ "$etype" == "checkout" ]]; then
      s_checkouts=$(( s_checkouts + 1 ))
    fi
  done <<< "$events_data"
  _flush_pattern_session

  local num_sessions=${#sess_durations[@]}

  # --- Context Switching ---
  echo ""
  echo "Context Switching"
  printf "%s\n" "────────────────────────────────────────────"

  local multi_repo_sessions=0 total_switches=0
  for (( i=0; i<num_sessions; i++ )); do
    if [[ "${sess_repo_counts[$i]}" -gt 1 ]]; then
      multi_repo_sessions=$(( multi_repo_sessions + 1 ))
    fi
    total_switches=$(( total_switches + ${sess_checkouts[$i]} ))
  done

  if [[ "$num_sessions" -gt 0 ]]; then
    local multi_pct
    multi_pct="$(awk "BEGIN { printf \"%.0f\", (${multi_repo_sessions}/${num_sessions})*100 }")"
    printf "  • Sessions:             %d\n" "$num_sessions"
    printf "  • Multi-repo sessions:  %d / %d (%s%%)\n" "$multi_repo_sessions" "$num_sessions" "$multi_pct"
    printf "  • Total branch switches: %d\n" "$total_switches"
    if [[ "$num_sessions" -gt 0 ]]; then
      local avg_switches
      avg_switches="$(awk "BEGIN { printf \"%.1f\", ${total_switches}/${num_sessions} }")"
      printf "  • Avg switches/session: %s\n" "$avg_switches"
    fi
  fi

  # --- Commit Cadence ---
  echo ""
  echo "Commit Cadence"
  printf "%s\n" "────────────────────────────────────────────"

  if [[ "$commits" -gt 1 ]]; then
    # Get time-since-last-commit values (repo-scoped)
    local cadence_data
    cadence_data="$(sqlite3 "$DB" "
      SELECT json_extract(payload, '$.time_since_last_commit_repo_seconds')
      FROM events WHERE ${where} AND event_type='commit'
      AND json_extract(payload, '$.time_since_last_commit_repo_seconds') > 0
      ORDER BY 1;" 2>/dev/null)"

    if [[ -n "$cadence_data" ]]; then
      local cadence_count median_val avg_val min_val max_val
      cadence_count="$(echo "$cadence_data" | wc -l | tr -d ' ')"
      min_val="$(echo "$cadence_data" | head -1)"
      max_val="$(echo "$cadence_data" | tail -1)"
      avg_val="$(echo "$cadence_data" | awk '{ sum += $1; n++ } END { printf "%.0f", sum/n }')"
      # Median
      local mid=$(( (cadence_count + 1) / 2 ))
      median_val="$(echo "$cadence_data" | sed -n "${mid}p")"

      printf "  • Commits with prior:   %d\n" "$cadence_count"
      printf "  • Median gap:           %s\n" "$(_engsight_format_duration "$median_val")"
      printf "  • Average gap:          %s\n" "$(_engsight_format_duration "$avg_val")"
      printf "  • Shortest gap:         %s\n" "$(_engsight_format_duration "$min_val")"
      printf "  • Longest gap:          %s\n" "$(_engsight_format_duration "$max_val")"
    else
      printf "  • Not enough sequential commits to measure cadence\n"
    fi
  else
    printf "  • Need 2+ commits to measure cadence\n"
  fi

  # --- Session Depth ---
  echo ""
  echo "Session Depth"
  printf "%s\n" "────────────────────────────────────────────"

  if [[ "$num_sessions" -gt 0 ]]; then
    # Categorize sessions
    local deep=0 moderate=0 shallow=0
    local total_duration=0 sessions_with_commits=0
    for (( i=0; i<num_sessions; i++ )); do
      total_duration=$(( total_duration + ${sess_durations[$i]} ))
      if [[ "${sess_commits[$i]}" -gt 0 ]]; then
        sessions_with_commits=$(( sessions_with_commits + 1 ))
      fi
      # Deep: single repo, 30+ min, 3+ commits
      if [[ "${sess_repo_counts[$i]}" -eq 1 && "${sess_durations[$i]}" -ge 1800 && "${sess_commits[$i]}" -ge 3 ]]; then
        deep=$(( deep + 1 ))
      # Shallow: <10 min or 0-1 commits
      elif [[ "${sess_durations[$i]}" -lt 600 || "${sess_commits[$i]}" -le 1 ]]; then
        shallow=$(( shallow + 1 ))
      else
        moderate=$(( moderate + 1 ))
      fi
    done

    local avg_duration
    avg_duration="$(awk "BEGIN { printf \"%.0f\", ${total_duration}/${num_sessions} }")"

    printf "  • Deep work (1 repo, 30m+, 3+ commits): %d sessions\n" "$deep"
    printf "  • Moderate:                              %d sessions\n" "$moderate"
    printf "  • Shallow (<10m or 0-1 commits):         %d sessions\n" "$shallow"
    printf "  • Average session duration:              %s\n" "$(_engsight_format_duration "$avg_duration")"
    printf "  • Total time in sessions:                %s\n" "$(_engsight_format_duration "$total_duration")"
  fi

  # --- AI Correlation ---
  echo ""
  echo "AI Correlation"
  printf "%s\n" "────────────────────────────────────────────"

  if [[ "$num_sessions" -gt 0 ]]; then
    local ai_sessions=0 solo_sessions=0
    local ai_total_commits=0 solo_total_commits=0
    local ai_total_files=0 solo_total_files=0
    local ai_total_duration=0 solo_total_duration=0

    for (( i=0; i<num_sessions; i++ )); do
      if [[ "${sess_ai_commits[$i]}" -gt 0 ]]; then
        ai_sessions=$(( ai_sessions + 1 ))
        ai_total_commits=$(( ai_total_commits + ${sess_commits[$i]} ))
        ai_total_files=$(( ai_total_files + ${sess_files[$i]} ))
        ai_total_duration=$(( ai_total_duration + ${sess_durations[$i]} ))
      elif [[ "${sess_commits[$i]}" -gt 0 ]]; then
        solo_sessions=$(( solo_sessions + 1 ))
        solo_total_commits=$(( solo_total_commits + ${sess_commits[$i]} ))
        solo_total_files=$(( solo_total_files + ${sess_files[$i]} ))
        solo_total_duration=$(( solo_total_duration + ${sess_durations[$i]} ))
      fi
    done

    printf "  • AI-assisted sessions: %d\n" "$ai_sessions"
    printf "  • Solo sessions:        %d\n" "$solo_sessions"

    if [[ "$ai_sessions" -gt 0 && "$solo_sessions" -gt 0 ]]; then
      local ai_avg_commits solo_avg_commits ai_avg_files solo_avg_files
      local ai_avg_duration solo_avg_duration
      ai_avg_commits="$(awk "BEGIN { printf \"%.1f\", ${ai_total_commits}/${ai_sessions} }")"
      solo_avg_commits="$(awk "BEGIN { printf \"%.1f\", ${solo_total_commits}/${solo_sessions} }")"
      ai_avg_files="$(awk "BEGIN { printf \"%.1f\", ${ai_total_files}/${ai_sessions} }")"
      solo_avg_files="$(awk "BEGIN { printf \"%.1f\", ${solo_total_files}/${solo_sessions} }")"
      ai_avg_duration="$(awk "BEGIN { printf \"%.0f\", ${ai_total_duration}/${ai_sessions} }")"
      solo_avg_duration="$(awk "BEGIN { printf \"%.0f\", ${solo_total_duration}/${solo_sessions} }")"

      echo ""
      printf "  %-28s %10s %10s\n" "" "AI" "Solo"
      printf "  %-28s %10s %10s\n" "────────────────────────────" "──────────" "──────────"
      printf "  %-28s %10s %10s\n" "Avg commits/session" "$ai_avg_commits" "$solo_avg_commits"
      printf "  %-28s %10s %10s\n" "Avg files changed/session" "$ai_avg_files" "$solo_avg_files"
      printf "  %-28s %10s %10s\n" "Avg session duration" "$(_engsight_format_duration "$ai_avg_duration")" "$(_engsight_format_duration "$solo_avg_duration")"
    elif [[ "$ai_sessions" -eq 0 && "$solo_sessions" -eq 0 ]]; then
      printf "  • No commit sessions to compare\n"
    else
      printf "  • Need both AI and solo sessions to compare\n"
    fi
  fi

  # --- Breadth ---
  echo ""
  echo "Breadth"
  printf "%s\n" "────────────────────────────────────────────"

  local unique_repos unique_branches
  unique_repos="$(sqlite3 "$DB" "SELECT COUNT(DISTINCT repo_name) FROM events WHERE ${where};")"
  unique_branches="$(sqlite3 "$DB" "SELECT COUNT(DISTINCT repo_name || '/' || branch) FROM events WHERE ${where};")"

  printf "  • Unique repos:         %d\n" "$unique_repos"
  printf "  • Unique branches:      %d (across all repos)\n" "$unique_branches"

  # Focus ratio: % of commits in top repo
  if [[ "$commits" -gt 0 ]]; then
    local top_repo top_commits
    top_repo="$(sqlite3 "$DB" "SELECT repo_name FROM events WHERE ${where} AND event_type='commit' GROUP BY repo_name ORDER BY COUNT(*) DESC LIMIT 1;")"
    top_commits="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND repo_name='${top_repo}';")"
    local focus_pct
    focus_pct="$(awk "BEGIN { printf \"%.0f\", (${top_commits}/${commits})*100 }")"
    printf "  • Focus ratio:          %s%% of commits in %s\n" "$focus_pct" "$top_repo"

    if [[ "$focus_pct" -ge 80 ]]; then
      printf "  • Assessment:           Focused — most work in one repo\n"
    elif [[ "$focus_pct" -ge 50 ]]; then
      printf "  • Assessment:           Balanced — primary repo with exploration\n"
    else
      printf "  • Assessment:           Spread — work distributed across repos\n"
    fi
  fi

  # File type diversity
  local file_types
  file_types="$(sqlite3 "$DB" "
    SELECT DISTINCT key FROM events,
      json_each(json_extract(payload, '$.file_types'))
    WHERE ${where} AND event_type='commit'
    AND key != '(none)';" 2>/dev/null || echo "")"

  if [[ -n "$file_types" ]]; then
    local type_count
    type_count="$(echo "$file_types" | wc -l | tr -d ' ')"
    local type_list
    type_list="$(echo "$file_types" | sort | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')"
    printf "  • File types touched:   %d (%s)\n" "$type_count" "$type_list"
  fi

  # Daily repo spread (how many repos per day)
  if [[ "$mode" != "daily" ]]; then
    echo ""
    echo "  Daily repo spread:"
    sqlite3 "$DB" "
      SELECT date(timestamp) as day, COUNT(DISTINCT repo_name) as repos,
        SUM(CASE WHEN event_type='commit' THEN 1 ELSE 0 END) as commits
      FROM events WHERE ${where}
      GROUP BY day ORDER BY day;" | while IFS='|' read -r day drepos dcommits; do
      printf "    %s: %d repos, %d commits\n" "$day" "$drepos" "$dcommits"
    done
  fi

  # --- Streaks ---
  echo ""
  echo "Streaks"
  printf "%s\n" "────────────────────────────────────────────"

  # Get all days with commits (across all time, not just the period — streaks span periods)
  local all_commit_days
  all_commit_days="$(sqlite3 "$DB" "SELECT DISTINCT date(timestamp) FROM events WHERE event_type='commit' ORDER BY 1;")"

  if [[ -n "$all_commit_days" ]]; then
    local current_streak=0 longest_streak=0 streak_start="" longest_start="" longest_end=""
    local prev_day="" today
    today="$(_engsight_date_ago 0)"

    while IFS= read -r day; do
      if [[ -z "$prev_day" ]]; then
        current_streak=1
        streak_start="$day"
      else
        # Check if this day is exactly 1 day after prev_day
        local prev_epoch day_epoch
        prev_epoch="$(_engsight_to_epoch "${prev_day}T00:00:00Z")"
        day_epoch="$(_engsight_to_epoch "${day}T00:00:00Z")"
        local gap_days=$(( (day_epoch - prev_epoch) / 86400 ))

        if [[ "$gap_days" -eq 1 ]]; then
          current_streak=$(( current_streak + 1 ))
        else
          if [[ "$current_streak" -gt "$longest_streak" ]]; then
            longest_streak="$current_streak"
            longest_start="$streak_start"
            longest_end="$prev_day"
          fi
          current_streak=1
          streak_start="$day"
        fi
      fi
      prev_day="$day"
    done <<< "$all_commit_days"

    # Final flush
    if [[ "$current_streak" -gt "$longest_streak" ]]; then
      longest_streak="$current_streak"
      longest_start="$streak_start"
      longest_end="$prev_day"
    fi

    # Is the current streak active (includes today or yesterday)?
    local last_commit_day
    last_commit_day="$(echo "$all_commit_days" | tail -1)"
    local last_epoch today_epoch days_since
    last_epoch="$(_engsight_to_epoch "${last_commit_day}T00:00:00Z")"
    today_epoch="$(_engsight_to_epoch "${today}T00:00:00Z")"
    days_since=$(( (today_epoch - last_epoch) / 86400 ))

    if [[ "$days_since" -le 1 ]]; then
      printf "  • Current streak:       %d days (since %s)\n" "$current_streak" "$streak_start"
    else
      printf "  • Current streak:       0 days (last commit: %s, %d days ago)\n" "$last_commit_day" "$days_since"
    fi
    printf "  • Longest streak:       %d days (%s to %s)\n" "$longest_streak" "$longest_start" "$longest_end"

    local total_commit_days
    total_commit_days="$(echo "$all_commit_days" | wc -l | tr -d ' ')"
    printf "  • Total active days:    %d\n" "$total_commit_days"

    # Days since last commit per repo (within period)
    local stale_repos
    stale_repos="$(sqlite3 "$DB" "
      SELECT repo_name, MAX(date(timestamp)) as last_day,
        CAST(julianday('now') - julianday(MAX(timestamp)) AS INTEGER) as days_ago
      FROM events WHERE ${where} AND event_type='commit'
      GROUP BY repo_name
      HAVING days_ago > 3
      ORDER BY days_ago DESC
      LIMIT 10;")"

    if [[ -n "$stale_repos" ]]; then
      echo ""
      echo "  Repos going quiet (no commits in 3+ days):"
      echo "$stale_repos" | while IFS='|' read -r rname last_day days_ago; do
        printf "    %-25s last commit %s (%d days ago)\n" "$rname" "$last_day" "$days_ago"
      done
    fi
  fi

  # --- File Hotspots ---
  echo ""
  echo "File Hotspots"
  printf "%s\n" "────────────────────────────────────────────"

  if [[ "$commits" -gt 0 ]]; then
    # Most frequently changed files across commits
    local hotspot_data
    hotspot_data="$(sqlite3 "$DB" "
      SELECT value, COUNT(*) as touches
      FROM events, json_each(json_extract(payload, '$.files'))
      WHERE ${where} AND event_type='commit'
      GROUP BY value
      HAVING touches > 1
      ORDER BY touches DESC
      LIMIT 15;" 2>/dev/null)"

    if [[ -n "$hotspot_data" ]]; then
      printf "  %-45s %s\n" "File" "Commits"
      echo "$hotspot_data" | while IFS='|' read -r filepath touches; do
        # Truncate long paths
        local display_path="$filepath"
        if [[ ${#display_path} -gt 43 ]]; then
          display_path="...${display_path: -40}"
        fi
        printf "  %-45s %d\n" "$display_path" "$touches"
      done
    else
      printf "  • No files touched in multiple commits\n"
    fi

    # Sole-author detection: files only you touch
    # (This is local-only data, so "sole author" = only author in engsight's history)
    local sole_author_files
    sole_author_files="$(sqlite3 "$DB" "
      SELECT value, COUNT(*) as touches
      FROM events, json_each(json_extract(payload, '$.files'))
      WHERE event_type='commit'
      GROUP BY value
      HAVING touches >= 5 AND COUNT(DISTINCT author) = 1
      ORDER BY touches DESC
      LIMIT 10;" 2>/dev/null)"

    if [[ -n "$sole_author_files" ]]; then
      echo ""
      echo "  Sole-author files (5+ commits, only you):"
      echo "$sole_author_files" | while IFS='|' read -r filepath touches; do
        local display_path="$filepath"
        if [[ ${#display_path} -gt 43 ]]; then
          display_path="...${display_path: -40}"
        fi
        printf "    %-43s %d commits\n" "$display_path" "$touches"
      done
    fi
  fi

  # --- Branch Lifecycle ---
  echo ""
  echo "Branch Lifecycle"
  printf "%s\n" "────────────────────────────────────────────"

  # Find branches: first seen (checkout/commit) to last seen (push/merge)
  local branch_data
  branch_data="$(sqlite3 "$DB" "
    SELECT repo_name || '/' || branch as full_branch,
      MIN(timestamp) as first_seen,
      MAX(timestamp) as last_seen,
      CAST((julianday(MAX(timestamp)) - julianday(MIN(timestamp))) * 24 AS INTEGER) as hours_lived,
      SUM(CASE WHEN event_type='commit' THEN 1 ELSE 0 END) as branch_commits,
      SUM(CASE WHEN event_type='push' THEN 1 ELSE 0 END) as branch_pushes
    FROM events
    WHERE ${where} AND branch != 'main' AND branch != 'master'
    GROUP BY full_branch
    HAVING branch_commits > 0
    ORDER BY hours_lived DESC
    LIMIT 15;" 2>/dev/null)"

  if [[ -n "$branch_data" ]]; then
    printf "  %-35s %8s %8s %8s\n" "Branch" "Lifespan" "Commits" "Pushes"
    printf "  %-35s %8s %8s %8s\n" "───────────────────────────────────" "────────" "────────" "────────"
    echo "$branch_data" | while IFS='|' read -r full_branch first_seen last_seen hours_lived branch_commits branch_pushes; do
      local lifespan
      if [[ "$hours_lived" -lt 1 ]]; then
        lifespan="<1h"
      elif [[ "$hours_lived" -lt 24 ]]; then
        lifespan="${hours_lived}h"
      else
        local days=$(( hours_lived / 24 ))
        lifespan="${days}d"
      fi

      local display_branch="$full_branch"
      if [[ ${#display_branch} -gt 33 ]]; then
        display_branch="...${display_branch: -30}"
      fi
      printf "  %-35s %8s %8d %8d\n" "$display_branch" "$lifespan" "$branch_commits" "$branch_pushes"
    done

    # Average branch lifespan
    local avg_hours
    avg_hours="$(sqlite3 "$DB" "
      SELECT AVG(hours_lived) FROM (
        SELECT CAST((julianday(MAX(timestamp)) - julianday(MIN(timestamp))) * 24 AS INTEGER) as hours_lived
        FROM events
        WHERE ${where} AND branch != 'main' AND branch != 'master'
        GROUP BY repo_name || '/' || branch
        HAVING SUM(CASE WHEN event_type='commit' THEN 1 ELSE 0 END) > 0
      );" 2>/dev/null)"

    if [[ -n "$avg_hours" && "$avg_hours" != "" ]]; then
      local avg_int
      avg_int="$(awk "BEGIN { printf \"%.0f\", ${avg_hours} }")"
      echo ""
      if [[ "$avg_int" -lt 24 ]]; then
        printf "  • Average branch lifespan: %sh\n" "$avg_int"
      else
        printf "  • Average branch lifespan: %sd\n" "$(( avg_int / 24 ))"
      fi
    fi
  else
    printf "  • No non-main branch activity in this period\n"
  fi
}

# --- diff command ---

# Helper: compute stats for a period, output as pipe-delimited values
_engsight_period_stats() {
  local ts_start="$1" ts_end="$2"
  local where="timestamp >= '${ts_start}' AND timestamp <= '${ts_end}'"

  local total commits checkouts pushes merges repos branches
  local ai_commits active_days
  total="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where};")"
  commits="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit';")"
  checkouts="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='checkout';")"
  pushes="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='push';")"
  merges="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='merge';")"
  repos="$(sqlite3 "$DB" "SELECT COUNT(DISTINCT repo_name) FROM events WHERE ${where};")"
  branches="$(sqlite3 "$DB" "SELECT COUNT(DISTINCT repo_name || '/' || branch) FROM events WHERE ${where};")"
  ai_commits="$(sqlite3 "$DB" "SELECT COUNT(*) FROM events WHERE ${where} AND event_type='commit' AND json_extract(payload, '$.ai_commit_signals.co_authored_by') != '[]';" 2>/dev/null || echo 0)"
  active_days="$(sqlite3 "$DB" "SELECT COUNT(DISTINCT date(timestamp)) FROM events WHERE ${where};")"

  echo "${total}|${commits}|${checkouts}|${pushes}|${merges}|${repos}|${branches}|${ai_commits}|${active_days}"
}

cmd_diff() {
  _engsight_check_db

  local mode="weekly" period_a="" period_b=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --weekly)   mode="weekly"; shift ;;
      --monthly)  mode="monthly"; shift ;;
      --period)   period_a="$2"; period_b="$3"; mode="custom"; shift 3 ;;
      -h|--help)  usage; exit 0 ;;
      *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local a_start a_end b_start b_end a_label b_label

  case "$mode" in
    weekly)
      b_start="$(_engsight_date_ago 7)"
      b_end="$(_engsight_date_ago 0)"
      a_start="$(_engsight_date_ago 14)"
      a_end="$(_engsight_date_ago 8)"
      a_label="Last week (${a_start} to ${a_end})"
      b_label="This week (${b_start} to ${b_end})"
      ;;
    monthly)
      b_start="$(_engsight_date_ago 30)"
      b_end="$(_engsight_date_ago 0)"
      a_start="$(_engsight_date_ago 60)"
      a_end="$(_engsight_date_ago 31)"
      a_label="Prior month (${a_start} to ${a_end})"
      b_label="This month (${b_start} to ${b_end})"
      ;;
    custom)
      if [[ -z "$period_a" || -z "$period_b" ]]; then
        echo "Error: --period requires two date ranges: YYYY-MM-DD..YYYY-MM-DD YYYY-MM-DD..YYYY-MM-DD" >&2
        exit 1
      fi
      a_start="${period_a%%..*}"
      a_end="${period_a##*..}"
      b_start="${period_b%%..*}"
      b_end="${period_b##*..}"
      a_label="Period A (${a_start} to ${a_end})"
      b_label="Period B (${b_start} to ${b_end})"
      ;;
  esac

  local a_ts_start="${a_start}T00:00:00Z" a_ts_end="${a_end}T23:59:59Z"
  local b_ts_start="${b_start}T00:00:00Z" b_ts_end="${b_end}T23:59:59Z"

  local a_stats b_stats
  a_stats="$(_engsight_period_stats "$a_ts_start" "$a_ts_end")"
  b_stats="$(_engsight_period_stats "$b_ts_start" "$b_ts_end")"

  IFS='|' read -r a_total a_commits a_checkouts a_pushes a_merges a_repos a_branches a_ai a_days <<< "$a_stats"
  IFS='|' read -r b_total b_commits b_checkouts b_pushes b_merges b_repos b_branches b_ai b_days <<< "$b_stats"

  echo "Diff"
  printf "%s\n" "════════════════════════════════════════════════════════════"
  echo "  A: ${a_label}"
  echo "  B: ${b_label}"
  echo ""

  # Delta display helper
  _diff_line() {
    local label="$1" a_val="$2" b_val="$3"
    local delta=$(( b_val - a_val ))
    local arrow=""
    if [[ "$delta" -gt 0 ]]; then
      arrow="(+${delta})"
    elif [[ "$delta" -lt 0 ]]; then
      arrow="(${delta})"
    else
      arrow="(=)"
    fi
    printf "  %-24s %8s %8s   %s\n" "$label" "$a_val" "$b_val" "$arrow"
  }

  printf "  %-24s %8s %8s   %s\n" "" "A" "B" "Delta"
  printf "  %-24s %8s %8s   %s\n" "────────────────────────" "────────" "────────" "─────────"
  _diff_line "Total events" "$a_total" "$b_total"
  _diff_line "Commits" "$a_commits" "$b_commits"
  _diff_line "Branch switches" "$a_checkouts" "$b_checkouts"
  _diff_line "Pushes" "$a_pushes" "$b_pushes"
  _diff_line "Merges" "$a_merges" "$b_merges"
  _diff_line "Active repos" "$a_repos" "$b_repos"
  _diff_line "Active branches" "$a_branches" "$b_branches"
  _diff_line "AI co-authored commits" "$a_ai" "$b_ai"
  _diff_line "Active days" "$a_days" "$b_days"

  # AI percentage comparison
  if [[ "$a_commits" -gt 0 || "$b_commits" -gt 0 ]]; then
    echo ""
    local a_ai_pct=0 b_ai_pct=0
    [[ "$a_commits" -gt 0 ]] && a_ai_pct="$(awk "BEGIN { printf \"%.0f\", (${a_ai}/${a_commits})*100 }")"
    [[ "$b_commits" -gt 0 ]] && b_ai_pct="$(awk "BEGIN { printf \"%.0f\", (${b_ai}/${b_commits})*100 }")"
    local pct_delta=$(( b_ai_pct - a_ai_pct ))
    local pct_arrow=""
    if [[ "$pct_delta" -gt 0 ]]; then pct_arrow="(+${pct_delta}pp)"
    elif [[ "$pct_delta" -lt 0 ]]; then pct_arrow="(${pct_delta}pp)"
    else pct_arrow="(=)"; fi
    printf "  %-24s %7s%% %7s%%   %s\n" "AI co-author rate" "$a_ai_pct" "$b_ai_pct" "$pct_arrow"
  fi

  # Repos that appeared/disappeared
  local a_repo_list b_repo_list
  a_repo_list="$(sqlite3 "$DB" "SELECT DISTINCT repo_name FROM events WHERE timestamp >= '${a_ts_start}' AND timestamp <= '${a_ts_end}';" 2>/dev/null | sort)"
  b_repo_list="$(sqlite3 "$DB" "SELECT DISTINCT repo_name FROM events WHERE timestamp >= '${b_ts_start}' AND timestamp <= '${b_ts_end}';" 2>/dev/null | sort)"

  local new_repos="" dropped_repos=""
  if [[ -n "$a_repo_list" || -n "$b_repo_list" ]]; then
    new_repos="$(comm -13 <(echo "$a_repo_list") <(echo "$b_repo_list") 2>/dev/null | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')"
    dropped_repos="$(comm -23 <(echo "$a_repo_list") <(echo "$b_repo_list") 2>/dev/null | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')"
  fi

  if [[ -n "$new_repos" || -n "$dropped_repos" ]]; then
    echo ""
    echo "  Repo changes:"
    if [[ -n "$new_repos" ]]; then printf "    New in B:     %s\n" "$new_repos"; fi
    if [[ -n "$dropped_repos" ]]; then printf "    Dropped in B: %s\n" "$dropped_repos"; fi
  fi
}

# --- Main ---
COMMAND="${1:-}"
[[ -n "$COMMAND" ]] && shift

case "$COMMAND" in
  init)       cmd_init ;;
  init-all)   cmd_init_all "${1:-}" ;;
  status)     cmd_status ;;
  log)        cmd_log "$@" ;;
  repos)      cmd_repos "$@" ;;
  summary)    cmd_summary "$@" ;;
  sessions)   cmd_sessions "$@" ;;
  patterns)   cmd_patterns "$@" ;;
  diff)       cmd_diff "$@" ;;
  -h|--help|"") usage ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    usage
    exit 1
    ;;
esac
