#!/usr/bin/env bash
# engsight configuration
# Copy to ~/.engsight/config and customize

# Database location
ENGSIGHT_DB="${ENGSIGHT_DB:-$HOME/.engsight/engsight.db}"

# Repos to exclude (space-separated paths)
ENGSIGHT_EXCLUDE_REPOS=()

# AI artifact paths to scan (relative to repo root)
ENGSIGHT_AI_ARTIFACTS=(
  .claude
  .cursor
  .cursorules
  .continue
  .continuerc.json
  .cline
  .clinerules
  ".aider*"
  .aider.conf.yml
  .windsurfrules
  .github/copilot-instructions.md
  CLAUDE.md
  AGENTS.md
  CODEX.md
  CRUSH.md
  docs/superpowers/specs
)

# Commit message patterns that suggest AI involvement
ENGSIGHT_AI_COMMIT_PATTERNS=(
  "Co-authored-by:.*Claude"
  "Co-authored-by:.*Copilot"
  "Co-authored-by:.*Cursor"
  "Generated by"
)

# Process sniffing: detect running AI tools at commit time
#   false — disabled (default)
#   true  — detect presence + resource stats via pgrep/ps (~50ms)
#   deep  — also scan open files and network connections via lsof (~200ms)
ENGSIGHT_PROCESS_SNIFF=false
ENGSIGHT_PROCESS_NAMES=(
  claude
  aider
  cursor
  copilot
  continue
  cline
  windsurf
  ollama
)

# Capture terminal/editor context ($TERM_PROGRAM)
ENGSIGHT_CAPTURE_TERMINAL=true

# Capture working directory state (untracked count, stash depth)
ENGSIGHT_CAPTURE_WORKDIR_STATE=true

# Explicitly tag time-of-day and day-of-week in payload
ENGSIGHT_TAG_TIME_CONTEXT=true
